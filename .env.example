# =============================================================================
# Second Brain — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# IMPORTANT:
#   - .env is gitignored and must NEVER be committed (secrets stay local/CI)
#   - This file (.env.example) IS committed with placeholder values only
#   - All values here are placeholders — never paste real secrets in this file
# =============================================================================


# =============================================================================
# DB — MySQL
# Used by: Docker Compose mysql service, FastAPI (SQLAlchemy async engine)
# =============================================================================

# MySQL superuser password (used by the mysql container at init time)
MYSQL_ROOT_PASSWORD=changeme-root

# Application database user (least-privilege — only has access to MYSQL_DATABASE)
MYSQL_USER=secondbrain

# Application database user password
MYSQL_PASSWORD=changeme-password

# Database name created at MySQL container init
MYSQL_DATABASE=secondbrain

# Full asyncmy DSN — used by SQLAlchemy create_async_engine in the FastAPI app
# Shape: mysql+asyncmy://<user>:<password>@<host>:<port>/<database>?charset=utf8mb4
# In Docker Compose, the host is the service name ("mysql"), not localhost
DATABASE_URL=mysql+asyncmy://secondbrain:changeme-password@mysql:3306/secondbrain?charset=utf8mb4


# =============================================================================
# JWT — Authentication
# Used by: app/core/security.py (Phase 2)
# =============================================================================

# Secret key used to sign JWT tokens — must be at least 32 random bytes in production
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme-jwt-secret-key-minimum-32-bytes-long

# Access token lifetime in minutes (recommended: 15 for security)
# See PITFALLS.md Pitfall 12: long-lived tokens are a security risk
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (recommended: 7-30)
REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT algorithm (HS256 is the standard for symmetric signing)
JWT_ALGORITHM=HS256


# =============================================================================
# Cloud AI — Anthropic
# Used by: app/ai/cloud_client.py (Phase 5 — RAG Q&A)
# =============================================================================

# Anthropic API key — get from https://console.anthropic.com/
# Never paste a real key here; use your local .env or CI secrets
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Anthropic model to use for RAG Q&A (see STACK.md for current model IDs)
# Recommended: claude-sonnet-4-5 (best quality/cost balance for RAG)
ANTHROPIC_MODEL=claude-sonnet-4-5


# =============================================================================
# Ollama — Local LLM
# Used by: app/ai/ollama_client.py (Phase 4 — summarisation, tagging, embeddings)
# =============================================================================

# Ollama service URL — in Docker Compose, use the service name (not localhost)
OLLAMA_BASE_URL=http://ollama:11434

# Model for summarisation and instruction-following tasks (~2 GB, runs on CPU)
OLLAMA_CHAT_MODEL=llama3.2:3b

# Model for text embeddings used in the RAG pipeline (274 MB)
OLLAMA_EMBED_MODEL=nomic-embed-text


# =============================================================================
# App — General
# Used by: app/core/config.py
# =============================================================================

# Environment name — controls log verbosity and debug features
# Values: development | production
ENVIRONMENT=development

# Log level for structured logging (structlog)
LOG_LEVEL=info
